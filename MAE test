import pandas as pd
import numpy as np


def evaluate_imputation_mae(source_path: str, imputed_path: str, sep: str = ",") -> None:

    # 1) wczytanie
    src = pd.read_csv(source_path, sep=sep)
    imp = pd.read_csv(imputed_path, sep=sep)

    # 2) szybkie kontrole
    if src.shape != imp.shape:
        raise ValueError(f"Różne wymiary plików: source={src.shape}, imputed={imp.shape}")
    if list(src.columns) != list(imp.columns):
        raise ValueError("Kolumny w plikach różnią się (inna kolejność lub nazwy).")

    # 3) ujednolicenie "udawanych braków" (opcjonalnie, ale pomaga po Excelu)
    src = src.replace(r"^\s*$", np.nan, regex=True)
    imp = imp.replace(r"^\s*$", np.nan, regex=True)

    # 4) tylko numeryczne (wspólne)
    num_cols = src.select_dtypes(include="number").columns.intersection(
        imp.select_dtypes(include="number").columns
    )

    if len(num_cols) == 0:
        raise ValueError("Brak wspólnych kolumn numerycznych do oceny.")

    # 5) MAE liczone tylko tam, gdzie w źródłowym były braki
    per_col = []
    all_abs_errors = []

    for col in num_cols:
        mask_missing = src[col].isna()

        n_missing = int(mask_missing.sum())
        if n_missing == 0:
            # nie ma czego oceniać dla tej kolumny
            per_col.append((col, 0, np.nan))
            continue

        # jeśli imputacja nie uzupełniła wszystkich braków, pomijamy te nadal brakujące
        valid_mask = mask_missing & imp[col].notna()
        n_used = int(valid_mask.sum())

        if n_used == 0:
            per_col.append((col, n_missing, np.nan))
            continue

        pass


    maes = []
    details = []
    for col in num_cols:
        m = src[col].notna() & imp[col].notna()
        n = int(m.sum())
        if n == 0:
            details.append((col, 0, np.nan))
            continue
        mae = float(np.mean(np.abs(src.loc[m, col] - imp.loc[m, col])))
        maes.append(mae)
        details.append((col, n, mae))

    overall = float(np.mean(maes)) if maes else np.nan

    print("\nMAE (tylko kolumny numeryczne) — porównanie source vs imputed na wspólnych nie-NaN")
    print(f"Kolumn numerycznych: {len(num_cols)}")
    print(f"MAE łączne (średnia po kolumnach): {overall:.6f}\n")

    print("MAE per kolumna:")
    for col, n, mae in details:
        mae_str = "brak danych" if np.isnan(mae) else f"{mae:.6f}"
        print(f" - {col}: n={n}, MAE={mae_str}")


